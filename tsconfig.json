{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "strictPropertyInitialization": false,
    "baseUrl": "./src",
    "allowJs": true,
    "paths": {
      "@modules/*": ["modules/*"],
      "@config/*": ["config/*"],
      "@shared/*": ["shared/*"],
      "@models/*": ["models/*"],
      "@utils/*": ["utils/*"],
      "@prisma/client": ["generated/prisma/client"]
    },
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "babel.config.js", "prettier.config.js", "prisma.config.ts"]
}
